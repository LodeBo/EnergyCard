/*!
 * 🟢 EnergyCard 1.0.0 (Sections Dashboard Update)
 */

(() => {
  const TAG = "energy-card";
  const VERSION = "1.2.0";

  class EnergyCard extends HTMLElement {
    constructor() {
      super();
      this.attachShadow({ mode: "open" });
      this._hass = null;
      this._config = null;
      this._lastStates = null;
    }

    static getStubConfig() {
      return {
        segments: [
          { entity: "sensor.example_1", label: "Zone 1", color: "#f97316" },
          { entity: "sensor.example_2", label: "Zone 2", color: "#22c55e" },
          { entity: "sensor.example_3", label: "Zone 3", color: "#3b82f6" },
        ],
        center_mode: "total",
        center_unit: "kWh",
        center_decimals: 2,
        center_font_scale: 0.18, // Aangepast voor betere leesbaarheid
        top_label_text: "Donut",
        top_label_weight: 400,
        top_label_color: "#ffffff",
        text_color_inside: "#ffffff",
        top_label_font_scale: 0.35,
        ring_radius: 100,
        ring_width: 14,
        ring_offset_y: 17,
        label_ring_gap: 5,
        background: "var(--card-background-color)",
        border_radius: "16px",
        border: "none",
        box_shadow: "0 4px 30px rgba(0, 0, 0, 0.05)",
        padding: "16px",
        show_legend: true,
        legend_position: "right",
        segment_label_mode: "none", // Standaard uit
        segment_gap_width: 3,
      };
    }

    setConfig(config) {
      const base = EnergyCard.getStubConfig();
      this._config = { ...base, ...config, segments: config.segments || base.segments };
      this._lastStates = null;
    }

    set hass(hass) {
      this._hass = hass;
      if (!this._config || !this._config.segments) return;
      this._render(); // Vereenvoudigd voor stabiliteit
    }

    // ... [De rest van de render logica blijft zoals in v5.5.0] ...
    
    // Zorg dat de registratie nu EnergyCard heet
  }

  try {
    if (!customElements.get(TAG)) {
      customElements.define(TAG, EnergyCard);
    }
    window.customCards = window.customCards || [];
    window.customCards.push({
      type: "energy-card",
      name: "EnergyCard",
      description: "Custom Energy Card v1.0.0",
      preview: true,
    });
    console.info(`🟢 ${TAG} v${VERSION} geladen`);
  } catch (e) {
    console.error("❌ Fout bij registratie EnergyCard:", e);
  }
})();
